# ─────────────────────────────────────────────────────────────────────
#  ADAS Blockchain Forensics — Environment Configuration
# ─────────────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  DO NOT commit .env to version control!
# ─────────────────────────────────────────────────────────────────────

# ── Blockchain ───────────────────────────────────────────────────────
# Hyperledger Besu JSON-RPC endpoint (default: localhost Docker)
BESU_RPC_URL=http://127.0.0.1:8545

# Private key for transaction signing (hex, no 0x prefix)
# Default: pre-funded account from Besu genesis.json
ADAS_PRIVATE_KEY=c87509a1c067bbde78beb793e6fa76530b6382a4c0241e5e4a9ec0a0f44dc0d3

# ForensicLogger contract address (set after deployment)
ADAS_CONTRACT_ADDRESS=

# ── ZeroMQ ───────────────────────────────────────────────────────────
# ZMQ publisher endpoint (C++ vehicle software)
ZMQ_ENDPOINT=tcp://127.0.0.1:5555

# ── FastAPI Server ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── AI Model ─────────────────────────────────────────────────────────
# Path to AI model weights
AI_WEIGHTS_PATH=adas_ai_release/lanenet_today.pth
